@model List<PLANETS_HOME.Models.Plant>
@{
    ViewData["Title"] = "Home";
}


<section class="hero">
    <h1>Find your perfect plant companion</h1>
    <p>Browse care guides — light, water, humidity and more.</p>
    <form asp-controller="Plants" asp-action="Index" method="get" class="hero-search">
        <input type="text" name="q" placeholder="Search plants…" class="search-input" />
        <button type="submit" class="btn-green">Search</button>
    </form>
</section>

<div class="container section">
    <h2 class="section-title">Featured plants</h2>
    <div class="plant-grid">
        @foreach (var plant in Model)
        {
            <a asp-controller="Plants" asp-action="Detail" asp-route-id="@plant.id" class="plant-card">
                <div class="plant-icon">🌱</div>
                <div class="plant-name">@plant.name</div>
                <span class="plant-tag">@plant.category</span>
            </a>
        }
    </div>
    <div style="text-align:center; margin-top:2rem;">
        <a asp-controller="Plants" asp-action="Index" class="btn-green">View all plants →</a>
    </div>
</div>
