<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Plants Home</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <nav class="navbar">
        
       <a class="navbar-brand" id="H" asp-controller="Home" asp-action="Index"><h1>🌿 Plants Home</h1></a>
        <div class="nav-links">
            <a asp-controller="Plants" asp-action="Index">Catalog</a>

            @if (Context.Session.GetString("UserRole") == "admin")
            {
                <a asp-controller="Admin" asp-action="Dashboard">Admin Panel</a>
                <a asp-controller="Account" asp-action="SignOut" class="btn-nav">Sign Out</a>
            }
            else if (Context.Session.GetInt32("UserId") != null)
            {
                <a asp-controller="Account" asp-action="Profile">@Context.Session.GetString("Username")</a>
                <a asp-controller="Account" asp-action="SignOut" class="btn-nav">Sign Out</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="SignIn" class="btn-nav">Sign In</a>
            }
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">@TempData["Success"]</div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <p>🌿 Planets Home — Your plant care companion</p>
    </footer>

</body>
</html>
