@{
}
@model PLANETS_HOME.Models.ViewModel.SignUpViewModel
@{
    ViewData["Title"] = "Sign Up";
}

<div class="form-page">
    <div class="form-card">
        <h1 class="form-title">Create account</h1>
        <p class="form-sub">Join to explore plant care guides</p>

        <form asp-action="SignUp" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="field">
                <label asp-for="Username">Username</label>
                <input asp-for="Username" placeholder="e.g. user" />
                <span asp-validation-for="Username" class="field-error"></span>
            </div>
            <div class="field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" placeholder="you@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>
            <div class="field">
                <label asp-for="ConfirmPassword">Confirm password</label>
                <input asp-for="ConfirmPassword" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-green btn-full">Create account</button>
        </form>

        <p class="link-row">
            Already have an account? <a asp-controller="Account" asp-action="SignIn">Sign in</a>
        </p>
    </div>
</div>
