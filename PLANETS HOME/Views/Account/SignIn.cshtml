@{
}
@model PLANETS_HOME.Models.ViewModel.SignInViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="form-page">
    <div class="form-card">
        <h1 class="form-title">Welcome back</h1>
        <p class="form-sub">Sign in to your account</p>

        <form asp-action="SignIn" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="field">
                <label asp-for="username">Username</label>
                <input asp-for="username" placeholder="user" />
                <span asp-validation-for="username" class="field-error"></span>
            </div>
            <div class="field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <button type="submit" class="btn-green btn-full">Sign in</button>
        </form>

        <p class="link-row">
            No account yet? <a asp-controller="Account" asp-action="SignUp">Sign up</a>
        </p>
    </div>
</div>
